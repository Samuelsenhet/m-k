# MÄÄK – landing-sajt på Loopia webbhotell (Apache 2.4 + nginx-proxy)
# Next.js static export. Bara statisk HTML.

RewriteEngine On

# Tvinga HTTPS – undanta ACME challenge (Let's Encrypt validering).
# Loopia har nginx framför Apache; %{HTTPS} är alltid "off" på Apache-nivån,
# så kolla X-Forwarded-Proto från nginx istället.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# /vilkor/ är svensk alias för /terms/ – Next's redirect() funkar inte i
# static export så vi gör 301 på Apache-nivå. Fullständig URL så att
# redirecten landar direkt på HTTPS (annars gissar Apache HTTP).
RewriteRule ^vilkor/?$ https://%{HTTP_HOST}/terms/ [L,R=301]

# Trailing slash på mappar — Apache mod_dir gör detta default men via HTTP.
# Stäng av mod_dir's auto-slash och lägg till egen regel som går direkt till HTTPS.
DirectorySlash Off
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ https://%{HTTP_HOST}/$1/ [L,R=301]

# Next static export skapar opengraph-image som fil utan extension. Tvinga image/png
# så sociala crawlers (Facebook, X, LinkedIn, Slack) ser den som riktig bild.
<Files "opengraph-image">
  ForceType image/png
</Files>
