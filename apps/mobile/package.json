{
  "name": "maak-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "expo:doctor": "npx expo-doctor",
    "eas:login": "npx eas-cli@^18.4.0 login",
    "eas:logout": "npx eas-cli@^18.4.0 logout",
    "eas:whoami": "npx eas-cli@^18.4.0 whoami",
    "eas:project:info": "npx eas-cli@^18.4.0 project:info",
    "eas:session": "npx eas-cli@^18.4.0 whoami && npx eas-cli@^18.4.0 project:info",
    "eas:credentials:ios": "npx eas-cli@^18.4.0 credentials --platform ios",
    "eas:update:configure": "npx eas-cli@^18.4.0 update:configure",
    "eas:build:dev:ios": "npx eas-cli@^18.4.0 build --profile expo-development --platform ios",
    "eas:build:preview": "npx eas-cli@^18.4.0 build --profile expo-preview --platform ios",
    "eas:build:preview:ios": "npx eas-cli@^18.4.0 build --profile expo-preview --platform ios",
    "eas:build:production:ios": "npx eas-cli@^18.4.0 build --profile expo-production --platform ios",
    "eas:build:production:ios:submit": "npx eas-cli@^18.4.0 build --profile expo-production --platform ios --auto-submit",
    "eas:workflow:testflight": "npx eas-cli@^18.4.0 workflow:run .eas/workflows/ios-testflight.yml --wait",
    "eas:workflow:app-store": "npx eas-cli@^18.4.0 workflow:run .eas/workflows/ios-app-store-submit.yml --wait",
    "mobile:eas:workflow:testflight": "npm run eas:workflow:testflight",
    "mobile:eas:workflow:app-store": "npm run eas:workflow:app-store"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.3.0",
    "@expo-google-fonts/space-mono": "^0.3.0",
    "@expo/vector-icons": "^15.0.3",
    "@maak/core": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.1.2",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.9",
    "expo-blur": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-document-picker": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.14",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "i18next": "^25.10.2",
    "lucide-react-native": "^1.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.0",
    "react-native": "0.83.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "autolinking": {
      "exclude": ["@capacitor/ios"]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@maak/core"
        ]
      }
    }
  },
  "private": true
}
