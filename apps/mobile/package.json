{
  "name": "maak-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "mobile": "expo start",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "start:localhost": "expo start --localhost",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "expo:doctor": "npx expo-doctor",
    "eas:login": "npx eas-cli@^18.4.0 login",
    "eas:logout": "npx eas-cli@^18.4.0 logout",
    "eas:whoami": "npx eas-cli@^18.4.0 whoami",
    "eas:project:info": "npx eas-cli@^18.4.0 project:info",
    "eas:session": "npx eas-cli@^18.4.0 whoami && npx eas-cli@^18.4.0 project:info",
    "eas:credentials:ios": "npx eas-cli@^18.4.0 credentials --platform ios",
    "eas:update:configure": "npx eas-cli@^18.4.0 update:configure",
    "eas:update:ios": "npx eas-cli@^18.4.0 update --platform ios",
    "eas:update:production:ios": "npx eas-cli@^18.4.0 update --channel production --platform ios --environment production",
    "eas:build:dev:ios": "npx eas-cli@^18.4.0 build --profile expo-development --platform ios --non-interactive",
    "eas:build:dev:ios:interactive": "npx eas-cli@^18.4.0 build --profile expo-development --platform ios",
    "eas:build:run:ios:latest": "npx eas-cli@^18.4.0 build:run --platform ios --latest",
    "eas:build:run:ios": "npx eas-cli@^18.4.0 build:run --platform ios",
    "eas:build:dev:ios:device": "npx eas-cli@^18.4.0 build --profile expo-development-device --platform ios --non-interactive",
    "eas:build:dev:ios:device:interactive": "npx eas-cli@^18.4.0 build --profile expo-development-device --platform ios",
    "eas:build:dev:android": "npx eas-cli@^18.4.0 build --profile expo-development --platform android --non-interactive",
    "eas:build:preview": "npx eas-cli@^18.4.0 build --profile expo-preview --platform ios",
    "eas:build:preview:ios": "npx eas-cli@^18.4.0 build --profile expo-preview --platform ios",
    "eas:build:production:ios": "npx eas-cli@^18.4.0 build --profile expo-production --platform ios",
    "eas:build:production:ios:submit": "npx eas-cli@^18.4.0 build --profile expo-production --platform ios --auto-submit",
    "eas:workflow:testflight": "npx eas-cli@^18.4.0 workflow:run .eas/workflows/ios-testflight.yml --wait",
    "eas:workflow:app-store": "npx eas-cli@^18.4.0 workflow:run .eas/workflows/ios-app-store-submit.yml --wait",
    "mobile:eas:workflow:testflight": "npm run eas:workflow:testflight",
    "mobile:eas:workflow:app-store": "npm run eas:workflow:app-store",
    "test": "jest",
    "test:mobile": "jest",
    "test:watch": "jest --watch",
    "test:web-vitest": "vitest run --config ../../config/vitest.config.ts",
    "test:web-vitest:watch": "vitest --config ../../config/vitest.config.ts"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.3.0",
    "@expo-google-fonts/space-mono": "^0.3.0",
    "@expo/vector-icons": "^15.0.3",
    "@maak/core": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.12",
    "expo-blur": "~55.0.13",
    "expo-camera": "~55.0.14",
    "expo-constants": "~55.0.12",
    "expo-dev-client": "~55.0.23",
    "expo-device": "^55.0.13",
    "expo-document-picker": "~55.0.12",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.13",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.17",
    "expo-linear-gradient": "~55.0.12",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.12",
    "expo-notifications": "^55.0.17",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~55.0.12",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-updates": "~55.0.19",
    "expo-video": "~55.0.14",
    "expo-web-browser": "~55.0.13",
    "i18next": "^25.10.2",
    "lucide-react-native": "^1.7.0",
    "posthog-react-native": "^4.41.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.0",
    "react-native": "0.83.4",
    "react-native-purchases": "^9.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webrtc": "^124.0.4",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-native/assets-registry": "^0.83.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "expect": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.14",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "@capacitor/ios"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@maak/core",
          "react-native-webrtc"
        ]
      }
    }
  },
  "private": true
}
