{
  "cli": {
    "version": ">=18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "extends": "expo-production"
    },
    "expo-development": {
      "node": "22.18.0",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "expo-development-device": {
      "node": "22.18.0",
      "developmentClient": true,
      "distribution": "internal"
    },
    "expo-preview": {
      "node": "22.18.0",
      "channel": "preview",
      "distribution": "internal"
    },
    "expo-production": {
      "node": "22.18.0",
      "channel": "production",
      "autoIncrement": true,
      "environment": "production",
      "distribution": "store"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "bundleIdentifier": "com.samuelsenhet.maak"
      }
    },
    "expo-production": {
      "extends": "production"
    }
  }
}
