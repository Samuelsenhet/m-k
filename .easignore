# EAS Build tarball exclusions (smaller upload).
# When present, EAS uses this instead of .gitignore for the project tarball.
# See: https://docs.expo.dev/build-reference/vcs/#uploading-the-project
# Note: .git is NOT excluded – EAS build:internal expects a git repo on the worker; excluding .git causes "Would you like us to run 'git init'?" and fails when stdin is not readable.

node_modules
dist
dist-ssr
*.log
logs
.expo/

# Docs - exclude markdown but keep mascot assets needed by build scripts
docs/*.md
docs/AGENTS.md
docs/MAAK_UNIVERSAL_AGENT_GUIDE.md

.cursor/
.roo/
*.local
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json

# iOS backups (not needed for EAS)
ios.backup/
ios.capacitor-backup/
ios.capacitor.backup/

# Capacitor (using Expo managed workflow)
capacitor.config.ts
capacitor.config.json

# Test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
