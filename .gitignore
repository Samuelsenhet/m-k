# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables - NEVER commit these
.env
.env.*
!.env.example
.env.local
.env.production
.env.development
.env.staging

# API keys and secrets (extra protection)
*.pem
*.key
secrets.json
credentials.json

# Capacitor
android/
# Capacitor iOS (ios/ can be generated with npx cap add ios)
ios/Pods/
ios/App/Pods/
ios/App/build/
ios/**/xcuserdata/

# MCP/Tool configs (may contain secrets)
.roo/
mcp.json

# Python (not used)
*.py
__pycache__/

# Expo (EAS only; do not commit)
.expo/

# Brownfield iOS build temporary backup (Capacitor ios/ while prebuild runs)
ios.capacitor.backup/
# General iOS backup / archive
ios.backup/

# Misc
.vercel
.env*.local
