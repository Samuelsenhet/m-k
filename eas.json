{
  "cli": {
    "version": ">=18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.12.0",
      "ios": {
        "config": "capacitor-ios.yml",
        "applicationArchivePath": "ios/App/build/App.ipa"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.12.0",
      "ios": {
        "config": "capacitor-ios.yml",
        "applicationArchivePath": "ios/App/build/App.ipa"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.12.0",
      "ios": {
        "config": "capacitor-ios.yml",
        "applicationArchivePath": "ios/App/build/App.ipa"
      }
    },
    "expo-development": {
      "node": "22.18.0",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "expo-preview": {
      "node": "22.18.0",
      "distribution": "internal"
    },
    "expo-production": {
      "node": "22.18.0",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
