{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "e2e-test": {
      "withoutCredentials": true,
      "ios": {
        "simulator": true,
        "config": "capacitor-ios.yml",
        "scheme": "App",
        "projectPath": "ios/App"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": { "config": "capacitor-ios.yml", "scheme": "App", "projectPath": "ios/App" }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "config": "capacitor-ios.yml",
        "scheme": "App",
        "projectPath": "ios/App"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "ios": { "config": "capacitor-ios.yml", "scheme": "App", "projectPath": "ios/App" }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "ios": { "config": "capacitor-ios.yml", "scheme": "App", "projectPath": "ios/App" }
    }
  },
  "submit": {
    "production": {}
  }
}
