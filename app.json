{
  "expo": {
    "name": "MĀĀK",
    "slug": "maak",
    "scheme": "maak",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "samuelsenhet",
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "MĀĀK needs access to your photos to let you choose profile pictures.",
          "cameraPermission": "MĀĀK needs access to your camera to take profile photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4AF37"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MĀĀK needs camera access for ID verification and profile photos."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "MĀĀK can help you find friends who are also using the app."
        }
      ]
    ],
    "runtimeVersion": "1.0.0",
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ],
      "package": "com.samuelsenhet.maak"
    },
    "ios": {
      "bundleIdentifier": "com.samuelsenhet.maak"
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "4d900a70-4327-4740-83cc-4ac6745ef8eb"
      }
    }
  }
}
