# =============================================================================
# MÄÄK – Environment variables (local + Vercel)
# =============================================================================
# ⚠️  SECURITY: Never commit real API keys to git!
# ⚠️  This .env.example is safe to commit (contains only placeholders)
# ⚠️  Your .env file is gitignored and should stay local only
# =============================================================================
# 1. Copy this file to .env:    cp .env.example .env
# 2. Replace the placeholder values below with your real Supabase values.
# 3. For Vercel: add the same names in Project → Settings → Environment Variables.
#
# Get values from: https://supabase.com/dashboard → your project → Settings → API
#
# Dashboard (only if you use email/password auth): Authentication → Password →
# “Leaked password protection”. Irrelevant for phone-OTP-only apps; advisor may still mention it.
# https://supabase.com/docs/guides/auth/password-security#password-strength-and-leaked-password-protection
# =============================================================================

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Supabase anon/public key (Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key-here"

# Supabase project reference ID (optional; used if URL is not set)
# Found in Project URL or Settings → General → Reference ID

# Optional: for npm run test:edge-match-daily (STEG 4). Dashboard → Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=
# Or use test user: SUPABASE_TEST_EMAIL= and SUPABASE_TEST_PASSWORD=

# Demo mode (optional). Set to "true" only for local demo; never in production.
# Default: unset/false. Production build throws if VITE_ENABLE_DEMO=true.
# VITE_ENABLE_DEMO=false

# App public URL (optional; for custom domain, e.g. https://maakapp.se)
# Set in Vercel env vars when using maakapp.se. See docs/DOMAIN_SETUP.md
# VITE_APP_URL="https://maakapp.se"

# TCP port for Vite dev server (default 8080). Set if 8080 is taken, e.g. by Expo: VITE_DEV_SERVER_PORT=5173
# VITE_DEV_SERVER_PORT=8080
#
# Local dev behind HTTPS reverse proxy / tunnel (REQUIRED for https://dev.maakapp.se).
# Fixes HMR WebSocket (wss) + asset URLs. Proxy must forward WebSocket upgrades to the same port.
# VITE_DEV_ORIGIN="https://dev.maakapp.se"
# If HMR still fails, temporarily: VITE_DISABLE_HMR=true (full page refresh only).
# VITE_DISABLE_HMR=false

# -----------------------------------------------------------------------------
# Loopia API (optional – only for scripts/loopia-dns.js)
# Create API user: Loopia Kundzon → Kontoinställningar → LoopiaAPI
# Never commit real credentials. Keep in .env (gitignored) or set when running.
# -----------------------------------------------------------------------------
# LOOPIA_API_USER="your-loopia-api-user@loopiaapi"
# LOOPIA_API_PASSWORD="your-loopia-api-password"
