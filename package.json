    "spellcheck": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\" --no-progress --relative",
    "spellcheck:fix": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\" --no-progress --no-summary",
