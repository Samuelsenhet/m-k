{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "dev:landing": "npm run dev --workspace=maak-landing",
    "build:landing": "npm run build --workspace=maak-landing",
    "dev:debug": "vite --debug --config config/vite.config.ts",
    "build": "vite build --config config/vite.config.ts",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "test:mobile": "npm run test --workspace=maak-mobile",
    "build:dev": "vite build --mode development --config config/vite.config.ts",
    "build:demo": "vite build --mode demo --config config/vite.config.ts",
    "lint": "eslint . --max-warnings 0 && npm run spellcheck",
    "postinstall": "patch-package",
    "typecheck": "tsc --noEmit",
    "spellcheck": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\" --no-progress --relative",
    "spellcheck:fix": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\" --no-progress --no-summary",
    "mascot": "node scripts/restore-mascot-workspace.mjs",
    "mascot:backup": "node scripts/backup-mascot-workspace.mjs",
    "mascot:verify": "node scripts/verify-mascot.mjs",
    "mascot:sync": "node scripts/sync-mascot-from-workspace.mjs",
    "mascot:sync-from-backup": "node scripts/sync-mascot-from-backup.mjs",
    "mascot:extract": "node scripts/extract-mascot.mjs",
    "mascot:sprite": "node scripts/build-mascot-sprite.mjs",
    "mascot:clean": "node scripts/crop-mascot-clean.mjs",
    "mascot:fix": "node scripts/fix-mascot-images.mjs",
    "launch:check": "node scripts/launch-check.mjs",
    "app-store:screenshots": "node scripts/resize-app-store-screenshots.mjs",
    "assets:app-store": "node scripts/build-app-store-assets.mjs",
    "edge:fix-401": "node scripts/set-edge-secrets-and-deploy.mjs",
    "edge:align-and-deploy": "node scripts/ensure-supabase-project-and-deploy.mjs",
    "test:edge-match-daily": "node scripts/invoke-match-daily-test.mjs",
    "preview": "vite preview --config config/vite.config.ts",
    "ios:build": "npm run build && npx cap sync ios",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:eas-build": "npm run eas:build:preview:ios --workspace=maak-mobile",
    "mobile:eas:build:production:ios": "npm run eas:build:production:ios --workspace=maak-mobile",
    "mobile:eas:build:production:ios:submit": "npm run eas:build:production:ios:submit --workspace=maak-mobile",
    "eas:build:dev:ios": "npm run eas:build:dev:ios --workspace=maak-mobile",
    "eas:build:dev:ios:interactive": "npm run eas:build:dev:ios:interactive --workspace=maak-mobile",
    "eas:build:run:ios:latest": "npm run eas:build:run:ios:latest --workspace=maak-mobile",
    "eas:build:run:ios": "npm run eas:build:run:ios --workspace=maak-mobile",
    "eas:build:dev:ios:device": "npm run eas:build:dev:ios:device --workspace=maak-mobile",
    "eas:build:dev:ios:device:interactive": "npm run eas:build:dev:ios:device:interactive --workspace=maak-mobile",
    "eas:build:dev:android": "npm run eas:build:dev:android --workspace=maak-mobile",
    "core:build": "npm run build --workspace=@maak/core",
    "mobile": "npm run start --workspace=maak-mobile",
    "mobile:ios": "npm run ios --workspace=maak-mobile",
    "eas:login": "npm run eas:login --workspace=maak-mobile",
    "eas:logout": "npm run eas:logout --workspace=maak-mobile",
    "eas:whoami": "npm run eas:whoami --workspace=maak-mobile",
    "eas:project:info": "npm run eas:project:info --workspace=maak-mobile",
    "eas:session": "npm run eas:session --workspace=maak-mobile",
    "mobile:eas:login": "npm run eas:login --workspace=maak-mobile",
    "mobile:eas:whoami": "npm run eas:whoami --workspace=maak-mobile",
    "mobile:eas:project:info": "npm run eas:project:info --workspace=maak-mobile",
    "mobile:eas:workflow:testflight": "npm run eas:workflow:testflight --workspace=maak-mobile",
    "mobile:eas:workflow:app-store": "npm run eas:workflow:app-store --workspace=maak-mobile",
    "mobile:eas:update:configure": "npm run eas:update:configure --workspace=maak-mobile",
    "mobile:eas:update:ios": "npm run eas:update:ios --workspace=maak-mobile",
    "mobile:eas:update:production:ios": "npm run eas:update:production:ios --workspace=maak-mobile",
    "mobile:expo:doctor": "npm run expo:doctor --workspace=maak-mobile",
    "vercel:env": "npx vercel env add VITE_SUPABASE_URL production && npx vercel env add VITE_SUPABASE_PUBLISHABLE_KEY production && npx vercel env add VITE_SUPABASE_PROJECT_ID production"
  },
