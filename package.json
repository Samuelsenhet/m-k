{
  "name": "maak-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:clean": "npx expo run:ios --no-build-cache",
    "ios:prebuild": "expo prebuild && expo run:ios",
    "prebuild": "expo prebuild",
    "test": "npx jest --config jest.config.cjs",
    "lint": "eslint . --max-warnings 0 && npm run spellcheck",
    "typecheck": "tsc --noEmit",
    "spellcheck": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\" --no-progress --relative",
    "mascot": "node scripts/restore-mascot-workspace.mjs",
    "mascot:backup": "node scripts/backup-mascot-workspace.mjs",
    "mascot:verify": "node scripts/verify-mascot.mjs",
    "mascot:sync": "node scripts/sync-mascot-from-workspace.mjs",
    "mascot:sync-from-backup": "node scripts/sync-mascot-from-backup.mjs",
    "mascot:extract": "node scripts/extract-mascot.mjs",
    "mascot:sprite": "node scripts/build-mascot-sprite.mjs",
    "mascot:clean": "node scripts/crop-mascot-clean.mjs",
    "mascot:fix": "node scripts/fix-mascot-images.mjs",
    "launch:check": "node scripts/launch-check.mjs",
    "edge:fix-401": "node scripts/set-edge-secrets-and-deploy.mjs",
    "edge:align-and-deploy": "node scripts/ensure-supabase-project-and-deploy.mjs",
    "test:edge-match-daily": "node scripts/invoke-match-daily-test.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
