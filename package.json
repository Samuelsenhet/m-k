  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "@xmldom/xmldom": ">=0.8.0",
    "@tootallnate/once": ">=3.0.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "patch-package": "^8.0.0",
    "@cspell/dict-sv": "^2.3.2",
    "@eslint/js": "^9.32.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "cspell": "^9.6.2",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "react-test-renderer": "18.3.1",
    "supabase": "^2.76.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  }
